#!/usr/bin/env fish

# Try extra hard to run a program without it discovering the dGPU, to make it
# not only select the iGPU, but also prevent it from waking the dGPU
# unnecessarily.

# First, check if this machine even has a dGPU. If it doesn't, just run the
# requested command as there is nothing to do.
if test (count /sys/class/drm/renderD*) -lt 2
  exec $argv
end

# To continue, we need bwrap. Complain if we don't have it.
if not type -fq bwrap
  echo "bwrap is not installed"
  exit 1
end

# export DXVK_FILTER_DEVICE_NAME="AMD Radeon 890M Graphics (RADV STRIX1)"
# export VKD3D_FILTER_DEVICE_NAME="AMD Radeon 890M Graphics (RADV STRIX1)"
# export MESA_VK_DEVICE_SELECT="1002:150e"
# export __GLX_VENDOR_LIBRARY_NAME="mesa"
# export __EGL_VENDOR_LIBRARY_FILENAMES="/usr/share/glvnd/egl_vendor.d/50_mesa.json"
# export __NV_PRIME_RENDER_OFFLOAD="0"
# export __VK_LAYER_NV_optimus="non_NVIDIA_only"
# export LIBVA_DRIVER_NAME="radeonsi"
# export VDPAU_DRIVER="va_gl"
# export WLR_RENDER_DRM_DEVICE="/dev/dri/by-path/pci-0000:67:00.0-render"
# export VK_DRIVER_FILES=/usr/share/vulkan/icd.d/radeon_icd.x86_64.json
# export DRI_PRIME=0

# https://gstreamer.freedesktop.org/documentation/gstreamer/running.html
set -x GST_PLUGIN_FEATURE_RANK "nvav1dec:NONE,nvh264dec:NONE,nvh265dec:NONE,nvjpegdec:NONE,nvmpeg2videodec:NONE,nvmpeg4videodec:NONE,nvmpegvideodec:NONE,nvvp8dec:NONE,nvvp9dec:NONE"

set -l cache_dir ~/.cache
set -l cache_file_name nvidia-libs.txt
set -l cache_file_path $cache_dir/$cache_file_name
set -l cache_valid_minutes 240

set -l fresh_cache_file (find $cache_dir -maxdepth 1 -mmin -$cache_valid_minutes -name $cache_file_name -print -quit 2> /dev/null)

# Find any library that could be part of the NVIDIA driver. These are files we
# want to prevent the child processes from being able to read in order to
# prevent them from using the NVIDIA GPU.
if test -z "$fresh_cache_file"
  # Rebuild cache
  find /usr -name '*nvidia*.so*' -type f 2> /dev/null > $cache_file_path
end

# Find the NVIDIA DRM device, so we can block it.
set -l dri_name (path basename /sys/module/nvidia/drivers/pci:nvidia/*/drm/renderD*)
set -l dri_path /dev/dri/$dri_name

# Start building the args we will pass to bwrap.
set -l bwrap_args --dev-bind / /

# Map DRI path to empty file.
set -a bwrap_args --bind /dev/zero $dri_path

# Map libraries to empty files.
# while read -l file
#   set -a bwrap_args --bind /dev/zero $file
# end < $cache_file_path

exec bwrap $bwrap_args $argv
