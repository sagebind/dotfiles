{
  "cli_default_open_behavior": "new_window",
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "agent": {
    "enabled": false,
    "dock": "left",
    "default_model": {
      "enable_thinking": false,
      "model": "gpt-4.1",
      "provider": "copilot_chat",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "base_keymap": "VSCode",
  "buffer_font_fallbacks": ["Hurmit Nerd Font", "monospace"],
  "buffer_font_family": "Hermit",
  "colorize_brackets": true,
  "current_line_highlight": "all",
  "cursor_shape": "block",
  "edit_predictions": {
    "ollama": {
      "api_url": "http://ollama.lan.internal:11434",
      "model": "hf.co/darrowoflykos/zeta-2-Q8_0-GGUF:Q8_0",
    },
    "provider": "copilot",
  },
  "ensure_final_newline_on_save": true,
  "file_types": {
    "xml": ["*.axaml"],
  },
  "format_on_save": "on",
  "gutter": {
    "folds": true,
  },
  "indent_guides": {
    "coloring": "indent_aware",
    "enabled": true,
  },
  "inlay_hints": {
    "enabled": true,
    "show_background": true,
  },
  "lsp_document_colors": "inlay",
  "minimap": {
    "show": "never",
  },
  "multi_cursor_modifier": "cmd_or_ctrl",
  "preview_tabs": {
    "enable_preview_from_project_panel": false,
  },
  "project_panel": {
    "default_width": 360.0,
    "dock": "right",
    "entry_spacing": "comfortable",
    "file_icons": true,
    "folder_icons": false,
    "hide_root": true,
    "indent_size": 24.0,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "show_edit_predictions": true,
  "show_whitespaces": "all",
  "tab_bar": {
    "show": true,
  },
  "tabs": {
    "file_icons": false,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "blinking": "on",
    "font_fallbacks": ["Hurmit Nerd Font", "monospace"],
    "font_family": "Hermit",
  },
  "theme": {
    "mode": "dark",
    "dark": "Kanagawa",
    "light": "One Light",
  },
  "title_bar": {
    "show_branch_icon": true,
    "show_branch_name": true,
    "show_menus": false,
    "show_onboarding_banner": false,
    "show_project_items": true,
    "show_sign_in": false,
    "show_user_menu": false,
    "show_user_picture": true,
  },
  "toolbar": {
    "agent_review": false,
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": false,
  },
  "ui_font_family": ".ZedSans",
  "ui_font_weight": 350.0,
  "window_decorations": "client",
  "wrap_guides": [80, 120],
  "linux": {
    "buffer_font_size": 15.0,
    "terminal": {
      "font_size": 15.0,
    },
    "ui_font_size": 18.0,
  },
  "macos": {
    "buffer_font_size": 13.0,
    "terminal": {
      "font_size": 13.0,
      "shell": {
        "program": "/opt/homebrew/bin/fish",
      },
    },
  },
  "languages": {
    "AsciiDoc": {
      "soft_wrap": "bounded",
    },
    "Markdown": {
      "soft_wrap": "bounded",
    },
    "YAML": {
      "format_on_save": "off",
      "tab_size": 2,
    },
  },
  "profiles": {
    "work": {
      "agent": {
        "profiles": {
          "ask": {
            "name": "Ask",
            "tools": {
              "diagnostics": true,
              "fetch": true,
              "list_directory": true,
              "project_notifications": false,
              "now": true,
              "find_path": true,
              "read_file": true,
              "open": true,
              "grep": true,
              "spawn_agent": true,
              "thinking": true,
              "update_plan": true,
              "web_search": true,
            },
            "enable_all_context_servers": false,
            "context_servers": {
              "mcp-server-buildkite": {
                "tools": {
                  "list_pipelines": true,
                },
              },
              "mcp-server-github": {
                "tools": {
                  "get_file_contents": true,
                  "search_repositories": true,
                  "search_pull_requests": true,
                  "search_issues": true,
                  "search_code": true,
                  "pull_request_read": true,
                  "list_pull_requests": true,
                  "list_commits": true,
                  "list_issues": true,
                  "list_branches": true,
                },
              },
              "com.atlassian/atlassian-mcp-server": {
                "tools": {
                  "getJiraIssue": true,
                  "getAccessibleAtlassianResources": true,
                },
              },
            },
          },
        },
        "default_profile": "write",
        "dock": "left",
        "tool_permissions": {
          "tools": {
            "mcp:mcp-server-github:list_branches": {
              "default": "allow",
            },
            "mcp:mcp-server-github:get_file_contents": {
              "default": "allow",
            },
            "mcp:mcp-server-github:search_repositories": {
              "default": "allow",
            },
            "mcp:mcp-server-github:search_pull_requests": {
              "default": "allow",
            },
            "mcp:mcp-server-github:search_issues": {
              "default": "allow",
            },
            "mcp:mcp-server-github:pull_request_read": {
              "default": "allow",
            },
            "mcp:mcp-server-buildkite:tail_logs": {
              "default": "allow",
            },
            "mcp:com.atlassian/atlassian-mcp-server:getJiraIssue": {
              "default": "allow",
            },
            "mcp:com.atlassian/atlassian-mcp-server:getAccessibleAtlassianResources": {
              "default": "allow",
            },
            "mcp:mcp-server-buildkite:read_logs": {
              "default": "allow",
            },
            "mcp:mcp-server-buildkite:search_logs": {
              "default": "allow",
            },
            "mcp:mcp-server-buildkite:get_build": {
              "default": "allow",
            },
            "terminal": {
              "always_allow": [
                {
                  "pattern": "^sleep\\s+\\d+\\s*$",
                },
                {
                  "pattern": "^ls[^;$()`|&]*$",
                },
                {
                  "pattern": "^./gradlew[^;$()`|&]*$",
                },
                {
                  "pattern": "^git commit -m \"[^\"$()`]+\"$",
                },
                {
                  "pattern": "^git push$",
                },
                {
                  "pattern": "^git\\s+commit(\\s|$)",
                },
              ],
              "always_deny": [
                { "pattern": "rm\\s+-rf\\s+(/|~)" },
                { "pattern": "sudo\\s+rm" },
                { "pattern": "gradle.+publish" },
              ],
              "always_confirm": [{ "pattern": "sudo\\s" }],
            },
            "mcp:mcp-server-buildkite:list_builds": {
              "default": "allow",
            },
          },
        },
        "default_model": {
          "effort": "medium",
          "enable_thinking": true,
          "model": "claude-sonnet-4.6",
          "provider": "copilot_chat",
        },
        "favorite_models": [],
        "model_parameters": [],
        "thread_summary_model": {
          "provider": "copilot_chat",
          "model": "gpt-4o",
        },
      },
      "format_on_save": "off",
    },
  },
}
